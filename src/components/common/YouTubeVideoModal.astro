---
interface Props {
  videoUrl?: string;
  showTrigger?: boolean;
}

const { videoUrl = '', showTrigger = true } = Astro.props;

function extractYouTubeId(url: string): string | null {
  const patterns = [
    /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/,
    /youtube\.com\/watch\?.*v=([a-zA-Z0-9_-]{11})/,
    /^([a-zA-Z0-9_-]{11})$/
  ];
  for (const pattern of patterns) {
    const match = url.match(pattern);
    if (match) return match[1];
  }
  return null;
}

const videoId = extractYouTubeId(videoUrl);
const embedUrl = videoId ? `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0` : '';
const hasContent = showTrigger ? !!videoId : true;
---

{hasContent && (
  <>
    {showTrigger && videoId && (
      <button
        type="button"
        class="youtube-modal-trigger inline-flex items-center justify-center"
        data-youtube-url={embedUrl}
        aria-label="Play video"
      >
        <slot />
      </button>
    )}

    <div
      id="youtubeModal"
      class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
    >
      <div id="youtubeModalInner" class="relative w-full max-w-[90vw] md:max-w-[80vw] lg:max-w-[900px]">
        <button
          type="button"
          id="youtubeModalClose"
          class="absolute -top-10 right-0 text-white hover:text-gray-300 transition-colors"
          aria-label="Close video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <div id="youtubeIframeContainer" class="relative w-full aspect-video bg-black rounded-lg overflow-hidden shadow-2xl">
          <iframe
            id="youtubeIframe"
            class="absolute inset-0 w-full h-full"
            src=""
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </>
)}

<script>
  function initYouTubeModal() {
    const modal = document.getElementById('youtubeModal');
    const iframe = document.getElementById('youtubeIframe') as HTMLIFrameElement | null;
    const closeBtn = document.getElementById('youtubeModalClose');
    if (!modal || !iframe || !closeBtn) return;

    // Avoid duplicate listeners on the same elements
    if ((modal as any).__ytModalBound) return;
    (modal as any).__ytModalBound = true;

    function openModal(url: string, isShort = false) {
      const inner = document.getElementById('youtubeModalInner');
      const container = document.getElementById('youtubeIframeContainer');
      const isMobile = window.innerWidth < 768;

      if (isShort && isMobile) {
        // Fullscreen en mobile
        modal!.classList.remove('bg-black/80', 'backdrop-blur-sm');
        modal!.classList.add('bg-black');
        if (inner) {
          inner.className = 'fixed inset-0 w-full h-full';
        }
        if (container) {
          container.className = 'w-full h-full';
        }
        if (closeBtn) {
          closeBtn.className = 'fixed top-4 right-4 z-[10000] text-white hover:text-gray-300 transition-colors';
        }
      } else {
        modal!.classList.add('bg-black/80', 'backdrop-blur-sm');
        modal!.classList.remove('bg-black');
        if (inner) {
          inner.className = 'relative w-full max-w-[90vw] md:max-w-[80vw] lg:max-w-[900px]';
        }
        if (container) {
          container.className = 'relative w-full aspect-video bg-black rounded-lg overflow-hidden shadow-2xl';
        }
        if (closeBtn) {
          closeBtn.className = 'absolute -top-10 right-0 text-white hover:text-gray-300 transition-colors';
        }
      }

      iframe!.src = url;
      modal!.classList.remove('hidden');
      modal!.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      iframe!.src = '';
      modal!.classList.add('hidden');
      modal!.classList.remove('flex');
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal!.classList.contains('hidden')) {
        closeModal();
      }
    });
  }

  // Listen for clicks globally (only bind once)
  if (!(window as any).__ytClickBound) {
    (window as any).__ytClickBound = true;
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest('[data-youtube-url]');
      if (trigger) {
        e.preventDefault();
        e.stopPropagation();
        const url = trigger.getAttribute('data-youtube-url');
        if (url) {
          const modal = document.getElementById('youtubeModal');
          const iframe = document.getElementById('youtubeIframe') as HTMLIFrameElement | null;
          if (modal && iframe) {
            const isShort = trigger.getAttribute('data-youtube-is-short') === 'true';
            const inner = document.getElementById('youtubeModalInner');
            const container = document.getElementById('youtubeIframeContainer');
            const closeBtn = document.getElementById('youtubeModalClose');
            const isMobile = window.innerWidth < 768;

            if (isShort && isMobile) {
              modal.classList.remove('bg-black/80', 'backdrop-blur-sm');
              modal.classList.add('bg-black');
              if (inner) inner.className = 'fixed inset-0 w-full h-full';
              if (container) container.className = 'w-full h-full';
              if (closeBtn) closeBtn.className = 'fixed top-4 right-4 z-[10000] text-white hover:text-gray-300 transition-colors';
            } else {
              modal.classList.add('bg-black/80', 'backdrop-blur-sm');
              modal.classList.remove('bg-black');
              if (inner) inner.className = 'relative w-full max-w-[90vw] md:max-w-[80vw] lg:max-w-[900px]';
              if (container) container.className = 'relative w-full aspect-video bg-black rounded-lg overflow-hidden shadow-2xl';
              if (closeBtn) closeBtn.className = 'absolute -top-10 right-0 text-white hover:text-gray-300 transition-colors';
            }

            iframe.src = url;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
          }
        }
      }
    });
  }

  initYouTubeModal();
  document.addEventListener('astro:page-load', initYouTubeModal);
</script>

<style>
  #youtubeIframeContainer iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
