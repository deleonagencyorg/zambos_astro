---
import LazyImage from '../common/LazyImage.astro';
import { getLocale } from '../../i18n/i18n';

interface Props {
  image: string;
  title: string;
  time?: string;
  id: string;
  description?: string;
  category?: string;
  isNew?: boolean;
}

const { 
  image, 
  title, 
  time = "30MIN", 
  id,
  description = '',
  category = 'breakfast',
  isNew = false
} = Astro.props;

const currentLocale = getLocale();
const recipeLink = `/${currentLocale}/${currentLocale === 'es' ? 'recetas' : 'recipes'}/${id}`;
---

<a 
  href={recipeLink} 
  class="block group h-full w-full"
>
  <div class={`overflow-hidden rounded-3xl transition-transform duration-300 hover:scale-[1.02] flex flex-col w-full ${currentLocale !== 'es' ? 'h-[384px] sm:h-[448px] md:h-[576px] lg:h-[672px]' : 'h-full'}`}>
    <!-- Imagen -->
    <div class={`relative overflow-hidden ${currentLocale !== 'es' ? 'h-[192px] sm:h-[224px] md:h-[288px] lg:h-[336px]' : 'h-[160px] sm:h-[180px] md:h-[250px]'}`}>
      <LazyImage
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
      />
    </div>
    
    <!-- Sección info -->
    <div class={`${currentLocale !== 'es' ? 'p-4 md:p-7 lg:p-9 h-[192px] sm:h-[224px] md:h-[288px] lg:h-[336px]' : 'p-3 md:p-6 flex-1'} flex flex-col ${currentLocale !== 'es' ? 'bg-[#97E66C]' : 'bg-[#FFED7A]'}`}>
      <!-- Category Tags -->
      <div class={`flex gap-2 ${currentLocale !== 'es' ? 'mb-3 md:mb-4' : 'mb-2 md:mb-3'} items-center`}>
        <span class={`inline-block px-3 py-1 md:px-4 md:py-2 font-bold text-xs uppercase text-white ${currentLocale !== 'es' ? 'bg-us-green rounded-lg' : 'bg-[#0DB04A] rounded-full'}`}>
          {category}
        </span>
        <!-- Tag NUEVO -->
        {isNew && (
          <span class="inline-block px-3 py-1 md:px-4 md:py-2 bg-us-tertiary text-white font-bold rounded-full text-xs uppercase">
            {currentLocale === 'es' ? 'NUEVO' : 'NEW'}
          </span>
        )}
      </div>

      <!-- Title -->
      <h3 class={`${currentLocale !== 'es' ? 'font-us-title' : 'font-title'} font-bold ${currentLocale !== 'es' ? 'text-[16px] sm:text-[18px] md:text-[20px] lg:text-[22px] leading-[1.1]' : 'text-base leading-tight sm:text-lg md:text-xl lg:text-2xl'} uppercase ${currentLocale !== 'es' ? 'text-us-green' : 'text-gray-900'} ${currentLocale === 'es' ? 'line-clamp-3 md:line-clamp-2' : ''}`}>
        {title}
      </h3>

      <p class={`${currentLocale !== 'es' ? 'font-us-text' : 'font-text'} ${currentLocale !== 'es' ? 'text-[13px] sm:text-[14px] md:text-[15px] lg:text-[16px] leading-relaxed' : 'text-sm leading-tight'} ${currentLocale !== 'es' ? 'mt-2 md:mt-3 line-clamp-3 sm:line-clamp-4' : 'hidden md:block mt-2 line-clamp-2'} ${currentLocale !== 'es' ? 'text-white' : 'text-gray-900'}`}>
        {description || (currentLocale === 'es' ? 'Deliciosa receta cargada de sabor perfecta para compartir en familia.' : 'Delicious recipe full of flavor perfect for sharing with family.')}
      </p>
    </div>
  </div>
</a>