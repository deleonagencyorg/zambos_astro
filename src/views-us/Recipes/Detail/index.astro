---
// src/views/Recipes/Detail/index.astro
import './styles.css';
import Breadcrumb from '../../../components/common/Breadcrumb/Breadcrumb.astro';
import LazyImage from '../../../components/common/LazyImage.astro';
import ShareModal from '../../../components/common/ShareModal.astro';
import ShareButton from '../../../components/common/ShareButton.astro';
import Subscription from '../../../components/subscription/index.astro';

interface RecipeItem {
  id: string;
  title: string;
  description: string;
  ingredients: string[];
  instructions: string[];
  preparation_time: number;
  servings: number;
  image?: string;
  tags?: string[];
  products?: string[];
}

interface ProductItem {
  id: string;
  name: string;
  image: string;
}

const { currentLang, recipeId } = Astro.props;

// Import all recipe files with static glob and filter by language
const recipeModules = import.meta.glob<{ default: RecipeItem }>("../../../locales/*/recipes/*.json");
const allRecipes: RecipeItem[] = [];
for (const path in recipeModules) {
  const lang = path.split('/') [4];
  if (lang === currentLang) {
    const mod = await recipeModules[path]();
    allRecipes.push(mod.default);
  }
}

// Import products for the current language
const productsData = await import(`../../../locales/${currentLang}/products.json`);
const allProducts: ProductItem[] = productsData.default?.items || [];

// Find current recipe
const recipe = allRecipes.find((item: RecipeItem) => item.id === recipeId);

const relatedRecipes = allRecipes.filter((item: RecipeItem) => item.id !== recipeId);
const RELATED_PAGE_SIZE = 12;

const canonicalShareUrl = new URL(`${Astro.url.pathname}${Astro.url.search}${Astro.url.hash}`, 'https://zambos.com').href;

if (!recipe) {
  throw new Error(`Recipe with id ${recipeId} not found`);
}

// Load shared recipe assets (titles, labels etc)
const recipesAssets = {
  recipes: currentLang === 'es' ? 'Ingredientes' : 'Ingredients',
  preparation: currentLang === 'es' ? 'Preparación' : 'Preparation',
  related_recipes: currentLang === 'es' ? 'Recetas relacionadas' : 'Related recipes'
};

// Amazon URL for buy button
const amazonBuyUrl = "https://www.amazon.com/stores/Zambos/Homepage/page/AB6B3C05-CBE2-49FD-8A2C-E5A7B1F57E2D";

function formatTime(minutes: number): string {
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  
  if (currentLang === 'es') {
    return hours > 0 
      ? `${hours}h ${mins}min` 
      : `${mins}min`;
  } else {
    return hours > 0 
      ? `${hours}h ${mins}m` 
      : `${mins}m`;
  }
}

// Get product info from recipe's products array (first product - position 0)
const productSlugs = recipe.products || [];
const firstProductSlug = productSlugs.length > 0 ? productSlugs[0] : null;
const productData = firstProductSlug ? allProducts.find((p: ProductItem) => p.id === firstProductSlug) : null;

// Use product data from products.json or defaults
const productName = productData?.name || (currentLang === 'es' ? 'Zambos' : 'Zambos');
const productImage = productData?.image || 'https://snack.yummiespromociones.com/SnacksyummiesAssets/zambos-ceviche-3d.png';
const servings = recipe.servings || 4;
---

<div class="min-h-screen md:bg-white recipe-detail-container relative">
   
  <!-- Mobile background - full page width and height of content -->
  <div class="absolute inset-0 w-full h-full bg-cover bg-center bg-no-repeat md:hidden z-0" style="background-image: url('https://snack.yummiespromociones.com/SnacksyummiesAssets/bgmobileusrecipe.webp');"></div>
  
  <!-- ===== HERO SECTION ===== -->
  <!-- Mobile: Stack vertical | Desktop: Side by side with equal heights -->
  <section class="relative w-full flex flex-col md:flex-row md:min-h-[600px] -mt-[80px] md:-mt-0 -lg:min-h-[650px] py-20 md:py-0">
    
    <!-- Recipe Image - Full width on mobile, narrower on desktop -->
    <div class="w-full md:w-[42%] lg:w-[60%] relative md:h-[600px] lg:h-[650px] overflow-hidden">
      {recipe.image && (
        <img 
          src={recipe.image} 
          alt={recipe.title}
          class="w-full h-full object-cover md:absolute md:inset-0"
        />
      )}
    </div>
    
    <!-- Recipe Info - Wider on desktop -->
    <div class="w-full md:w-[70%] lg:w-[90%] relative flex flex-col justify-center md:h-[600px] lg:h-[650px] md:ml-[-15%] md:px-4 md:px-0 lg:px-20">
      <!-- Mobile background layer -->
      <div class="absolute inset-0 bg-cover bg-center bg-no-repeat md:hidden" style="background-image: url('https://snack.yummiespromociones.com/SnacksyummiesAssets/bgrecipestimeusmobile.webp');"></div>
      <!-- Desktop background layer -->
      <div class="absolute inset-0 bg-cover bg-center bg-no-repeat hidden md:block" style="background-image: url('https://snack.yummiespromociones.com/SnacksyummiesAssets/detailzambosusrecipe.webp');"></div>
      
      <!-- Content layer -->
      <div class="relative z-10">

      
      <div class="p-[6%] md:p-[8%] lg:p-[10%] w-full">
        <!-- Title - Centered on mobile, left on desktop -->
        <h1 class="font-bold text-[7vw] md:text-[3.5vw] lg:text-[2.8vw] text-white uppercase mb-[4%] leading-[1.1] text-center md:text-left">
          {recipe.title}
        </h1>
        
        <!-- Description -->
        <p class="text-white/90 text-[3.5vw] md:text-[1.2vw] lg:text-[1vw] mb-[6%] leading-relaxed text-center md:text-left max-w-full md:max-w-[90%]">
          {recipe.description || (currentLang === 'es' 
            ? 'Crujientes dedos de pescado cubiertos con Zambos Ceviche triturados y cítricos frescos. Un platillo dorado ideal para compartir y acompañar con tu salsa favorita.' 
            : 'Crispy fish fingers coated with crunchy Zambos Ceviche crumbs and fresh citrus flavors. A tasty, golden dish ideal for sharing and pairing with your favorite sauce.')}
        </p>
        
        <!-- Icons Row - Time and Servings -->
        <div class="flex flex-wrap justify-center md:justify-start gap-[6%] mb-[6%]">
          <!-- Prep Time -->
          <div class="flex flex-col items-center text-white">
            <div class="w-[8vw] h-[8vw] md:w-[3vw] md:h-[3vw] max-w-[48px] max-h-[48px] mb-[5%]">
              <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/zambostime.png" alt="Prep time" class="w-full h-full object-contain" />
            </div>
            <span class="text-[2.8vw] md:text-[0.9vw] uppercase font-semibold opacity-90">{currentLang === 'es' ? 'Prep time' : 'Prep time'}</span>
            <span class="text-[4vw] md:text-[1.4vw] font-bold">{formatTime(recipe.preparation_time)}</span>
          </div>
          
          <!-- Servings -->
          <div class="flex flex-col items-center text-white">
            <div class="w-[8vw] h-[8vw] md:w-[3vw] md:h-[3vw] max-w-[48px] max-h-[48px] mb-[5%]">
              <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/zambosportions.png" alt="Servings" class="w-full h-full object-contain" />
            </div>
            <span class="text-[2.8vw] md:text-[0.9vw] uppercase font-semibold opacity-90">{currentLang === 'es' ? 'Servings' : 'Servings'}</span>
            <span class="text-[4vw] md:text-[1.4vw] font-bold">{servings}-{servings + 1} {currentLang === 'es' ? 'portions' : 'portions'}</span>
          </div>
        </div>
        
        <!-- Social Share Icons - Light green rounded squares -->
        <div class="flex justify-center md:justify-start gap-[3%]">
          <button 
            class="w-[12vw] h-[12vw] md:w-[4vw] md:h-[4vw] max-w-[48px] max-h-[48px] rounded-xl bg-[#A8D648] flex items-center justify-center hover:bg-[#9AC43F] transition-colors shadow-md active:scale-95" 
            aria-label="Share on Instagram"
            onclick="window.open('https://instagram.com', '_blank')"
          >
            <svg class="w-[6vw] h-[6vw] md:w-[2vw] md:h-[2vw] max-w-[24px] max-h-[24px] text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </button>
          <button 
            class="w-[12vw] h-[12vw] md:w-[4vw] md:h-[4vw] max-w-[48px] max-h-[48px] rounded-xl bg-[#A8D648] flex items-center justify-center hover:bg-[#9AC43F] transition-colors shadow-md active:scale-95" 
            aria-label="Share on Facebook"
            onclick="window.open('https://facebook.com', '_blank')"
          >
            <svg class="w-[6vw] h-[6vw] md:w-[2vw] md:h-[2vw] max-w-[24px] max-h-[24px] text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </button>
          <button 
            class="w-[12vw] h-[12vw] md:w-[4vw] md:h-[4vw] max-w-[48px] max-h-[48px] rounded-xl bg-[#A8D648] flex items-center justify-center hover:bg-[#9AC43F] transition-colors shadow-md active:scale-95" 
            aria-label="Share Recipe"
            onclick="document.getElementById('shareModal-recipe')?.classList.remove('hidden')"
          >
            <svg class="w-[6vw] h-[6vw] md:w-[2vw] md:h-[2vw] max-w-[24px] max-h-[24px] text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <circle cx="18" cy="5" r="3"/>
              <circle cx="6" cy="12" r="3"/>
              <circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
          </button>
          <button 
            class="w-[12vw] h-[12vw] md:w-[4vw] md:h-[4vw] max-w-[48px] max-h-[48px] rounded-xl bg-[#A8D648] flex items-center justify-center hover:bg-[#9AC43F] transition-colors shadow-md active:scale-95" 
            aria-label="Copy Link"
            onclick="navigator.clipboard.writeText(window.location.href)"
          >
            <svg class="w-[6vw] h-[6vw] md:w-[2vw] md:h-[2vw] max-w-[24px] max-h-[24px] text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- White decorative line - full viewport width at bottom of hero, desktop only -->

  </section>

  <section class="relative w-full pb-[8%] md:pb-[5%] pt-[2%] md:pt-[0]">
  <img 
      src="https://snack.yummiespromociones.com/SnacksyummiesAssets/linewhiteus.webp" 
      alt="" 
      class="hidden md:block absolute top-0  lg:-mt-[120px] left-0 w-screen z-20 pointer-events-none"
    /> 
    
    <div class="relative flex flex-col items-center text-center px-[5%]">
      <!-- Product Package Image - More spacing from top section -->
      <div class="relative w-[80%] md:w-[30%] lg:w-[25%] max-w-[400px] mb-[3%] z-30 drop-shadow-2xl mt-[0] md:mt-[3%] mx-auto">
        <img 
          src={productImage} 
          alt={productName}
          class="w-full h-auto object-contain transform hover:scale-105 transition-transform duration-300"
        />
      </div>
      
      <!-- Made With Text - Red color matching design -->
      <p class="text-white md:text-[#B71C1C] font-bold text-[4vw] md:text-[1.5vw] lg:text-[1.2vw] uppercase tracking-wider mb-[1%]">
        {currentLang === 'es' ? 'Hecho con' : 'Made With'}
      </p>
      
      <!-- Product Name - Green color matching design -->
      <div class="relative inline-block mb-[4%]">
        <h2 class="text-white md:text-[#0E6D20] font-bold text-[7vw] md:text-[3vw] lg:text-[2.5vw] uppercase leading-tight">
          {productName}
        </h2>
        <!-- Floating chip - desktop only -->
        <div class="absolute -right-[50%] -top-[20%] w-[20%] md:w-[40%] pointer-events-none animate-float hidden md:block">
          <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/chip1zambosus.webp" alt="" class="w-full h-auto object-contain drop-shadow-lg" />
        </div>
      </div>
      
      <!-- Buy Product Button - Red pill with white text -->
      <a 
        href={amazonBuyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-[8px] bg-[#B71C1C] text-white font-bold px-[6%] py-[2.5%] md:px-[3%] md:py-[1.2%] rounded-full hover:bg-[#9A1616] transition-all shadow-lg text-[3.5vw] md:text-[1.2vw] lg:text-[1vw] active:scale-95 hover:shadow-xl"
      >
        <span class="uppercase tracking-wide">{currentLang === 'es' ? 'COMPRAR PRODUCTO' : 'BUY PRODUCT'}</span>
        <svg class="w-[4vw] h-[4vw] md:w-[1.2vw] md:h-[1.2vw] max-w-[18px] max-h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </a>
    </div>
  </section>
   <section class="w-full py-[8%] md:py-[5%] relative">

    <div class="w-full px-[5%] md:px-[8%] lg:px-[10%] max-w-[1400px] mx-auto">
      <!-- Mobile: Stack vertical | Desktop: Side by side -->
      <div class="flex flex-col lg:flex-row gap-[6%]">
        
        <!-- Ingredients Column -->
        <div class="w-full lg:w-[47%] mb-[8%] lg:mb-0">
          <!-- Red Header Pill -->
          <div class="flex justify-center lg:justify-start mb-[4%]">
            <div class="bg-[#B71C1C] text-white py-[2%] px-[6%] md:py-[1.5%] md:px-[4%] rounded-full inline-block">
              <h2 class="font-bold text-[4vw] md:text-[1.5vw] lg:text-[1.2vw] uppercase tracking-wider whitespace-nowrap">
                {recipesAssets.recipes}
              </h2>
            </div>
          </div>
          
           <!-- Ingredients List with Checkbox Style -->
          <ul class="space-y-[3%]">
            {recipe.ingredients.map((ingredient: string) => (
              <li class="flex items-start gap-[3%] text-white md:text-[#0E6D20]">
                <!-- Checkbox square with red border matching design -->
                <span class="w-[4vw] h-[4vw] md:w-[1.2vw] md:h-[1.2vw] max-w-[16px] max-h-[16px] border-2 border-[#B71C1C] rounded-sm mt-[0.5%] flex-shrink-0 flex items-center justify-center">
                  <span class="w-[60%] h-[60%] bg-[#B71C1C] rounded-[1px]"></span>
                </span>
                <span class="text-[3.5vw] md:text-[1.2vw] lg:text-[1vw] leading-relaxed font-medium">{ingredient}</span>
              </li>
            ))}
          </ul>
          
          <!-- Desktop chip below Ingredients -->
          <div class="hidden lg:block absolute -bottom-[20%] left-[5%] w-[12%]  pointer-events-none animate-float z-20">
            <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/chip2zambosus.webp" alt="" class="w-full h-auto object-contain drop-shadow-lg" />
          </div>
        </div>
        
        <!-- Preparation Column -->
        <div class="w-full lg:w-[47%]">
          <!-- Red Header Pill -->
          <div class="flex justify-center lg:justify-start mb-[4%]">
            <div class="bg-[#B71C1C] text-white py-[2%] px-[6%] md:py-[1.5%] md:px-[4%] rounded-full inline-block">
              <h2 class="font-bold text-[4vw] md:text-[1.5vw] lg:text-[1.2vw] uppercase tracking-wider whitespace-nowrap">
                {recipesAssets.preparation}
              </h2>
            </div>
          </div>
          
          <!-- Preparation Steps with Styled Numbers -->
          <ol class="space-y-[4%]">
            {recipe.instructions.map((instruction: string, index: number) => (
              <li class="flex items-start gap-[4%]">
                <!-- Number in green with underline decoration matching design -->
                <span class="flex-shrink-0 text-white md:text-[#B71C1C] font-bold text-[4vw] md:text-[1.4vw] lg:text-[1.2vw] leading-none pt-[0.5%]">
                  {index + 1}.
                </span>
                <p class="text-white md:text-[#0E6D20] text-[3.5vw] md:text-[1.2vw] lg:text-[1vw] leading-relaxed font-medium">{instruction}</p>
              </li>
            ))}
          </ol>
          
          <!-- Desktop chip below Preparation -->
          <div class="hidden lg:block absolute -bottom-[10%] right-[5%] w-[8%]  pointer-events-none animate-float z-20" style="animation-delay: 0.8s;">
            <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/chip3zambosus.webp" alt="" class="w-full h-auto object-contain drop-shadow-lg" />
          </div>
        </div>
        
        <!-- Mobile chip below Preparation, right-aligned overlapping Explore More -->
        <div class="lg:hidden absolute -bottom-[5%] right-[3%] w-[15%] max-w-[80px] pointer-events-none animate-float z-30">
          <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/chip1zambosus.webp" alt="" class="w-full h-auto object-contain drop-shadow-lg" />
        </div>
        
      </div>
    </div>
    
  </section>
  
 <!-- ===== EXPLORE MORE RECIPES SECTION ===== -->
  <section class="w-full py-[8%] md:py-[5%] bg-cover bg-center bg-no-repeat relative overflow-hidden" >
    

    
    
  </section>

<div class="w-full min-h-screen pt-[10%] md:py-[5%] explore-more-bg relative z-[1]">
 
<div class="w-full px-[5%] md:px-[8%] md:pt-[20%] lg:px-[10%] max-w-[1400px] mx-auto">
      <!-- Title left-aligned -->
      <div class="mb-[5%]">
        <h2 class="font-bold uppercase leading-[1.05]">
          <span class="block text-[9vw] md:text-[5vw] lg:text-[4vw] text-[#A8D648]">
            {currentLang === 'es' ? 'EXPLORA MÁS' : 'EXPLORE MORE'}
          </span>
          <span class="block text-[9vw] md:text-[5vw] lg:text-[4vw] text-white">
            {currentLang === 'es' ? 'RECETAS ZAMBOS' : 'ZAMBOS RECIPES'}
          </span>
        </h2>
      </div>
    <!-- Floating chip decoration - desktop only, absolute left -->
    <div class="hidden md:block absolute top-[58%] left-[2%] w-[17%] pointer-events-none animate-float z-30">
      <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/chip1zambosus.webp" alt="" class="w-full h-auto object-contain drop-shadow-lg" />
    </div>
      <!-- Carousel Container -->
      <div class="relative">
        <!-- Recipe Cards Carousel -->
        <div class="flex overflow-x-auto snap-x snap-mandatory gap-0 md:gap-[4%] pb-[3%] md:pb-0 scrollbar-hide" id="recipeCarousel">
          {relatedRecipes.slice(0, 6).map((relatedRecipe, index) => (
            <a 
              href={`/${currentLang}/${currentLang === 'es' ? 'recetas' : 'recipes'}/${relatedRecipe.id}`}
              class="group block bg-white rounded-[3vw] md:rounded-[1.5vw] lg:rounded-[1vw] overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 flex-shrink-0 w-full md:w-[48%] snap-start"
            >
              <!-- Image -->
              <div class="relative aspect-[16/10] overflow-hidden">
                <img
                  src={relatedRecipe.image || '/images/recipes/placeholder.jpg'}
                  alt={relatedRecipe.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
              </div>
              <!-- Content -->
              <div class="p-[5%] md:p-[4%]">
                <!-- Category Badge -->
                <span class="inline-block px-[3%] py-[1%] bg-[#0E6D20] text-white font-bold text-[2.5vw] md:text-[0.8vw] lg:text-[0.7vw] uppercase rounded-md mb-[2%]">
                  {currentLang === 'es' ? 'APERITIVO' : 'APPETIZER'}
                </span>
                <!-- Title -->
                <h3 class="font-bold text-[#0E6D20] text-[3.5vw] md:text-[1.3vw] lg:text-[1.1vw] uppercase leading-tight mb-[2%]">
                  {relatedRecipe.title}
                </h3>
                <!-- Description -->
                <p class="text-[#0E6D20]/70 text-[3vw] md:text-[0.9vw] lg:text-[0.8vw] line-clamp-2">
                  {relatedRecipe.description || (currentLang === 'es' 
                    ? 'Deliciosa receta preparada con Zambos.' 
                    : 'Delicious recipe prepared with Zambos.')}
                </p>
              </div>
            </a>
          ))}
        </div>
        
        <!-- Navigation Arrows - Red square with white icon -->
        <button 
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-[50%] md:-translate-x-[80%] w-[8vw] h-[8vw] md:w-[3vw] md:h-[3vw] max-w-[40px] max-h-[40px] bg-[#B71C1C] rounded-lg flex items-center justify-center shadow-lg hover:bg-[#9A1616] transition-colors z-30 active:scale-95"
          onclick="document.getElementById('recipeCarousel').scrollBy({left: -300, behavior: 'smooth'})"
          aria-label="Previous recipe"
        >
          <svg class="w-[4vw] h-[4vw] md:w-[1.5vw] md:h-[1.5vw] max-w-[20px] max-h-[20px] text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button 
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-[50%] md:translate-x-[80%] w-[8vw] h-[8vw] md:w-[3vw] md:h-[3vw] max-w-[40px] max-h-[40px] bg-[#B71C1C] rounded-lg flex items-center justify-center shadow-lg hover:bg-[#9A1616] transition-colors z-30 active:scale-95"
          onclick="document.getElementById('recipeCarousel').scrollBy({left: 300, behavior: 'smooth'})"
          aria-label="Next recipe"
        >
          <svg class="w-[4vw] h-[4vw] md:w-[1.5vw] md:h-[1.5vw] max-w-[20px] max-h-[20px] text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>

      <!-- Floating chip - mobile only, below carousel, right-aligned -->
      <div class="flex md:hidden justify-end mt-[4%] pr-[2%]">
        <div class="w-[18%] max-w-[80px] pointer-events-none animate-float">
