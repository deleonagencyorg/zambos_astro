---
// src/views/Recipes/Detail/index.astro
import './styles.css';
import RecipesCarousel from '../../../components/recipes/RecipesCarousel.astro';
import Breadcrumb from '../../../components/common/Breadcrumb/Breadcrumb.astro';
import LazyImage from '../../../components/common/LazyImage.astro';
import IngredientsCarousel from '../../../components/recipes/IngredientsCarousel.astro';
import ShareModal from '../../../components/common/ShareModal.astro';
import ShareButton from '../../../components/common/ShareButton.astro';
import Subscription from '../../../components/subscription/index.astro';

interface RecipeItem {
  id: string;
  title: string;
  description: string;
  ingredients: string[];
  instructions: string[];
  preparation_time: number;
  servings: number;
  image?: string;
  tags?: string[];
  product_image?: string;
}

const { currentLang, recipeId } = Astro.props;

// Import all recipe files with static glob and filter by language
const recipeModules = import.meta.glob<{ default: RecipeItem }>("../../../locales/*/recipes/*.json");
const allRecipes: RecipeItem[] = [];
for (const path in recipeModules) {
  const lang = path.split('/') [4];
  if (lang === currentLang) {
    const mod = await recipeModules[path]();
    allRecipes.push(mod.default);
  }
}

// Find current recipe
const recipe = allRecipes.find((item: RecipeItem) => item.id === recipeId);

const relatedRecipes = allRecipes.filter((item: RecipeItem) => item.id !== recipeId);
const RELATED_PAGE_SIZE = 12;

const canonicalShareUrl = new URL(`${Astro.url.pathname}${Astro.url.search}${Astro.url.hash}`, 'https://zambos.com').href;

if (!recipe) {
  throw new Error(`Recipe with id ${recipeId} not found`);
}

// Load shared recipe assets (titles, labels etc)
const recipesAssets = {
  recipes: currentLang === 'es' ? 'Ingredientes' : 'Ingredients',
  preparation: currentLang === 'es' ? 'Preparación' : 'Preparation',
  related_recipes: currentLang === 'es' ? 'Recetas relacionadas' : 'Related recipes'
};

function formatTime(minutes: number): string {
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  
  if (currentLang === 'es') {
    return hours > 0 
      ? `${hours}h ${mins}min` 
      : `${mins}min`;
  } else {
    return hours > 0 
      ? `${hours}h ${mins}m` 
      : `${mins}m`;
  }
}
---
<div class=" min-h-screen   bg-cover bg-center bg-no-repeat" style="background-image: url('https://snack.yummiespromociones.com/SnacksyummiesAssets/recetasdetalleus.webp');">


  <!-- Main Recipe Card -->
  <section class="flex  justify-center items-center py-6 sm:py-8 px-2 sm:px-4">
    <div class=" border-2 bg-us-green border-white/20 rounded-3xl p-4 sm:p-6 md:p-12 w-full max-w-6xl">
      <div class="flex flex-col md:flex-row gap-8">
        
        <!-- Left Side - Images -->
        <div class="w-full md:w-1/2">
          <!-- Main Image -->
          <div class="relative rounded-3xl overflow-hidden mb-4">
            {recipe.image && (
              <LazyImage
                src={recipe.image} 
                alt={recipe.title}
                class="w-full h-[320px] sm:h-[400px] object-cover"
                transition:name={`recipe-image-${recipe.id}`}
              />
            )}
            
            <!-- Tags on image -->
            <div class="absolute top-4 left-4 flex gap-2">
              <span class="px-4 py-2 bg-us-red text-white font-bold rounded-full text-xs uppercase">
                APPETIZER
              </span>
              <span class="px-4 py-2 bg-us-red text-white font-bold rounded-full text-xs uppercase">
                NEW
              </span>
            </div>
          </div>
        </div>

        <!-- Right Side - Info -->
        <div class="w-full md:w-1/2">
          <!-- Title -->
          <h1 class="font-title text-xl md:text-2xl font-bold text-white mb-6 uppercase">
            {recipe.title}
          </h1>

          <!-- Time & Difficulty -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
            <!-- Time -->
            <div class="bg-white rounded-2xl p-4">
              <div class="flex items-center gap-2 text-us-green mb-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-xs sm:text-sm font-bold uppercase">{currentLang === 'es' ? 'Tiempo' : 'Time'}</span>
              </div>
              <p class="text-us-green font-bold">{formatTime(recipe.preparation_time)}</p>
            </div>

            <!-- Difficulty -->
            <div class="bg-white rounded-2xl p-4">
              <div class="flex items-center gap-2 text-us-green mb-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <span class="text-xs sm:text-sm font-bold uppercase">{currentLang === 'es' ? 'Dificultad' : 'Difficulty'}</span>
              </div>
              <p class="text-us-green font-bold">
                {currentLang === 'es' ? 'Fácil' : 'Easy'}
              </p>
            </div>
          </div>

          <!-- Tab Buttons -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-6">
            <button 
              id="ingredientsTab"
              class="tab-btn tab-active bg-us-red text-white font-bold py-2.5 sm:py-3 px-4 sm:px-6 rounded-xl uppercase hover:opacity-90 transition text-sm sm:text-base"
            >
              {recipesAssets.recipes}
            </button>
            <button 
              id="preparationTab"
              class="tab-btn tab-inactive bg-white text-us-green border-2 border-us-green font-bold py-2.5 sm:py-3 px-4 sm:px-6 rounded-xl uppercase hover:bg-gray-100 transition text-sm sm:text-base"
            >
              {recipesAssets.preparation}
            </button>
          </div>

          <!-- Content Area -->
          <div class="bg-white rounded-2xl p-4 sm:p-6 mb-6 min-h-[200px]">
            <!-- Ingredients Content -->
            <div id="ingredientsContent" class="tab-content">
              <ul class="space-y-3">
                {recipe.ingredients.map((ingredient: string) => (
                  <li class="flex items-start gap-3">
                    <span class="text-us-green mt-1">•</span>
                    <span class="text-us-green">{ingredient}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Preparation Content -->
            <div id="preparationContent" class="tab-content hidden">
              <ol class="space-y-4">
                {recipe.instructions.map((instruction: string, index: number) => (
                  <li class="flex items-start gap-3">
                    <span class="font-bold text-us-green">{index + 1}.</span>
                    <span class="text-us-green">{instruction}</span>
                  </li>
                ))}
              </ol>
            </div>
          </div>

          <!-- Social Buttons -->
          <div class="flex gap-3">
            <div class="bg-us-red rounded-full w-12 h-12 flex items-center justify-center hover:opacity-90 transition shadow-md">
              <ShareButton platform="instagram" url={canonicalShareUrl} className="w-6 h-6 text-white [&_svg]:fill-white [&_svg]:stroke-white" />
            </div>
            <div class="bg-us-red rounded-full w-12 h-12 flex items-center justify-center hover:opacity-90 transition shadow-md">
              <ShareButton platform="facebook" url={canonicalShareUrl} className="w-6 h-6 text-white [&_svg]:fill-white [&_svg]:stroke-white" />
            </div>
            <div class="bg-us-red rounded-full w-12 h-12 flex items-center justify-center hover:opacity-90 transition shadow-md">
              <ShareButton platform="tiktok" url={canonicalShareUrl} className="w-6 h-6 text-white [&_svg]:fill-white [&_svg]:stroke-white" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Recipes Section -->
  <!-- Explore More Recipes Section -->
  <section class="py-12 px-4 bg-cover bg-center bg-no-repeat" style="background-image: url('https://snack.yummiespromociones.com/SnacksyummiesAssets/bg-explore-more.webp');">
    <div class="w-full max-w-6xl mx-auto">
      <!-- Title -->
      <div class="mb-10">
        <h2 class="font-us-title font-bold uppercase leading-none">
          <span class="block text-3xl sm:text-4xl md:text-6xl lg:text-7xl text-[#A8D648]" style="white-space: nowrap;">
            {currentLang === 'es' ? 'EXPLORA MÁS' : 'EXPLORE MORE'}
          </span>
          <span class="block text-3xl sm:text-4xl md:text-6xl lg:text-7xl text-white" style="white-space: nowrap;">
            {currentLang === 'es' ? 'RECETAS ZAMBOS' : 'ZAMBOS RECIPES'}
          </span>
        </h2>
      </div>

      <!-- Carousel with White Cards -->
      <div class="relative explore-carousel-container">
        <!-- Prev Button -->
        <button
          type="button"
          class="explore-carousel-prev absolute left-0 top-1/2 z-50 bg-[#B71C1C] text-white w-10 h-10 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center opacity-100 hover:scale-110 transition-all duration-300 shadow-xl"
          style="transform: translateY(-50%);"
          aria-label="Previous"
        >
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <!-- Carousel Grid -->
        <div class="explore-recipes-grid flex gap-4 overflow-hidden px-12 sm:px-16">
          {relatedRecipes.slice(0, 6).map((recipe) => (
            <div class="explore-recipe-card flex-shrink-0 w-full sm:w-[calc(50%-8px)]" data-recipe-id={recipe.id}>
              <a href={`/${currentLang}/${currentLang === 'es' ? 'recetas' : 'recipes'}/${recipe.id}`} class="block group h-full">
                <div class="bg-white rounded-2xl overflow-hidden shadow-lg transition-transform duration-300 hover:scale-[1.02] h-full flex flex-col">
                  <!-- Image -->
                  <div class="relative h-48 sm:h-56 overflow-hidden">
                    <img
                      src={recipe.image || '/images/recipes/placeholder.jpg'}
                      alt={recipe.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    />
                  </div>
                  <!-- Content -->
                  <div class="p-4 flex flex-col flex-1">
                    <!-- Category Badge -->
                    <span class="inline-block self-start px-3 py-1 bg-[#0E6D20] text-white font-bold text-xs uppercase rounded-md mb-2">
                      APPETIZER
                    </span>
                    <!-- Title -->
                    <h3 class="font-bold text-[#0E6D20] text-sm sm:text-base uppercase leading-tight mb-2 flex-1">
                      {recipe.title}
                    </h3>
                    <!-- Description -->
                    <p class="text-[#B71C1C] text-xs sm:text-sm line-clamp-3">
                      {recipe.description || (currentLang === 'es' ? 'Deliciosa receta preparada con Zambos.' : 'Delicious recipe prepared with Zambos.')}
                    </p>
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>

        <!-- Next Button -->
        <button
          type="button"
          class="explore-carousel-next absolute right-0 top-1/2 z-50 bg-[#B71C1C] text-white w-10 h-10 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center opacity-100 hover:scale-110 transition-all duration-300 shadow-xl"
          style="transform: translateY(-50%);"
          aria-label="Next"
        >
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>

      <style>
        .explore-carousel-container {
          position: relative;
          width: 100%;
        }

        .explore-recipes-grid {
          display: flex;
          flex-wrap: nowrap;
          justify-content: flex-start;
          align-items: stretch;
        }

        .explore-recipe-card {
          flex: 0 0 100%;
          max-width: 100%;
          transition: all 0.3s ease;
        }

        /* Mobile: 1 card */
        @media (max-width: 639px) {
          .explore-recipe-card {
            flex: 0 0 100%;
            max-width: 100%;
          }
        }

        /* Desktop: 2 cards */
        @media (min-width: 640px) {
          .explore-recipes-grid {
            gap: 16px;
          }
          
          .explore-recipe-card {
            flex: 0 0 calc(50% - 8px);
            max-width: calc(50% - 8px);
          }
        }

        .explore-carousel-prev,
        .explore-carousel-next {
          cursor: pointer;
          pointer-events: auto;
        }

        .explore-carousel-prev:hover,
        .explore-carousel-next:hover {
          transform: translateY(-50%) scale(1.1);
        }

        .explore-carousel-prev:active,
        .explore-carousel-next:active {
          transform: translateY(-50%) scale(0.95);
        }
      </style>

      <script>
        (function() {
          const container = document.querySelector('.explore-carousel-container');
          if (!container) return;

          const prevBtn = container.querySelector('.explore-carousel-prev');
          const nextBtn = container.querySelector('.explore-carousel-next');
          const track = container.querySelector('.explore-recipes-grid');
          const cards = container.querySelectorAll('.explore-recipe-card');

          if (!prevBtn || !nextBtn || !track || !cards.length) return;

          let currentPage = 0;
          const itemsPerPage = window.innerWidth < 640 ? 1 : 2;
          const totalPages = Math.ceil(cards.length / itemsPerPage);

          function showPage(page) {
            page = Math.max(0, Math.min(page, totalPages - 1));
            currentPage = page;

            const offset = page * 100;
            track.style.transform = `translateX(-${offset}%)`;

            // Update button states
            prevBtn.style.opacity = currentPage === 0 ? '0.4' : '1';
            nextBtn.style.opacity = currentPage >= totalPages - 1 ? '0.4' : '1';
          }

          prevBtn.addEventListener('click', () => showPage(currentPage - 1));
          nextBtn.addEventListener('click', () => showPage(currentPage + 1));

          // Initialize
          showPage(0);

          // Handle resize
          window.addEventListener('resize', () => {
            const newItemsPerPage = window.innerWidth < 640 ? 1 : 2;
            if (newItemsPerPage !== itemsPerPage) {
              location.reload();
            }
          });
        })();
      </script>

      <!-- View All Button -->
      <div class="flex justify-center mt-8">
        <a
          href={`/${currentLang}/${currentLang === 'es' ? 'recetas' : 'recipes'}`}
          class="bg-us-red text-white font-bold px-10 py-4 rounded-full hover:opacity-90 transition uppercase"
        >
          {currentLang === 'es' ? 'VER TODAS' : 'VIEW ALL'}
        </a>
      </div>
  </section>

  
</div>

<!-- Tab Switching Script -->
<script>
  function initRecipeTabs() {
    const ingredientsTab = document.getElementById('ingredientsTab');
    const preparationTab = document.getElementById('preparationTab');
    const ingredientsContent = document.getElementById('ingredientsContent');
    const preparationContent = document.getElementById('preparationContent');

    if (!ingredientsTab || !preparationTab || !ingredientsContent || !preparationContent) return;
    if (ingredientsTab.dataset.bound === 'true') return;
    ingredientsTab.dataset.bound = 'true';

    ingredientsTab.addEventListener('click', () => {
      ingredientsTab.classList.add('tab-active', 'bg-us-red', 'text-white');
      ingredientsTab.classList.remove('tab-inactive', 'bg-white', 'text-us-green');
      preparationTab.classList.add('tab-inactive', 'bg-white', 'text-us-green');
      preparationTab.classList.remove('tab-active', 'bg-us-red', 'text-white');
      ingredientsContent.classList.remove('hidden');
      preparationContent.classList.add('hidden');
    });

    preparationTab.addEventListener('click', () => {
      preparationTab.classList.add('tab-active', 'bg-us-red', 'text-white');
      preparationTab.classList.remove('tab-inactive', 'bg-white', 'text-us-green');
      ingredientsTab.classList.add('tab-inactive', 'bg-white', 'text-us-green');
      ingredientsTab.classList.remove('tab-active', 'bg-us-red', 'text-white');
      preparationContent.classList.remove('hidden');
      ingredientsContent.classList.add('hidden');
    });
  }

  document.addEventListener('DOMContentLoaded', initRecipeTabs);
  document.addEventListener('astro:page-load', initRecipeTabs);
  document.addEventListener('astro:after-swap', initRecipeTabs);
</script>

<!-- Share Modal -->
<ShareModal
  id="shareModal-recipe"
  url={canonicalShareUrl}
  title={recipe.title}
  description={recipe.description}
  hashtags={recipe.tags || []}
  showLabels={false}
  iconSize={40}
  round={true}
  openTextEs="Comparte esta receta en tus redes sociales"
  openTextEn="Share this recipe on your social networks"
  acceptTextEs="Aceptar"
  acceptTextEn="Accept"
/>

